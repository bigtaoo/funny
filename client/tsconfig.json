{
  "compilerOptions": {
    "module": "ESNext",
    "target": "ES2020",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@nw/engine": ["../server/engine/src/index.ts"],
      "@nw/engine/*": ["../server/engine/src/*"],
      "@nw/shared": ["../server/shared/src/index.ts"]
    }
  },
  "include": ["src/**/*", "../server/engine/src/**/*", "../server/shared/src/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "src/assetsManager",
    "src/inputSystem",
    "src/index.ts",
    "src/wechatIndex.ts",
    "src/game/gameScene.ts",
    "src/game/grid.ts",
    "src/game/numbers.ts",
    "src/game/header.ts",
    "src/game/display.ts",
    "src/game/effectManager.ts",
    "src/game/effect.ts",
    "src/game/logic.ts",
    "src/game/helper.ts",
    "src/game/enums.ts",
    "src/game/consts.ts"
  ]
}

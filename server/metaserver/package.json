{
  "name": "@nw/metaserver",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit",
    "dev": "node --watch --import tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "tsc -b && vitest run",
    "gen:api:contracts": "node ../contracts/scripts/bundle-openapi.mjs",
    "gen:api:contracts:check": "node ../contracts/scripts/bundle-openapi.mjs --check",
    "gen:api:server": "node ../contracts/scripts/gen-openapi-server.mjs",
    "gen:api:server:check": "node ../contracts/scripts/gen-openapi-server.mjs --check",
    "proto:gen": "node scripts/gen-proto.mjs"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.12.0",
    "@fastify/cors": "^10.0.1",
    "@nw/engine": "*",
    "@nw/shared": "*",
    "fastify": "^5.1.0",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@bufbuild/buf": "^1.70.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.0",
    "ts-proto": "^2.11.8",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}

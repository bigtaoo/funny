{
  "name": "@nw/server",
  "version": "0.1.0",
  "private": true,
  "description": "Notebook Wars 服务端：metaserver(REST) + gateway(控制面 WS) + matchsvc(私有匹配大脑) + gameserver(数据面 WS) + commercial(钱包/交易) + shared + contracts",
  "workspaces": [
    "shared",
    "metaserver",
    "gateway",
    "matchsvc",
    "gameserver",
    "commercial",
    "admin"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "dev:meta": "npm run dev --workspace @nw/metaserver",
    "dev:game": "npm run dev --workspace @nw/gameserver",
    "dev:gateway": "npm run dev --workspace @nw/gateway",
    "dev:matchsvc": "npm run dev --workspace @nw/matchsvc",
    "dev:commercial": "npm run dev --workspace @nw/commercial",
    "dev:admin": "npm run dev --workspace @nw/admin",
    "dev:all": "powershell -NoProfile -ExecutionPolicy Bypass -File dev-up.ps1",
    "test": "npm run test --workspaces --if-present"
  },
  "engines": {
    "node": ">=20"
  }
}

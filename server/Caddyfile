# Reverse proxy (C-3 / S1-M / S8): /api/* → metaserver, /gw → gateway (control-plane WS), /ws → gameserver (data-plane WS),
# /world,/auction,/sect,/nation → worldsvc (SLG overworld REST + sect/world chat), /social/* → socialsvc (social fifth public face).
# Site address injected via {$NW_DOMAIN}:
#   · Real domain (e.g. nw.example.com) → Caddy auto-provisions Let's Encrypt certificate, full HTTPS/WSS.
#   · Default :80 → HTTP only (for local / no-domain integration testing; no certificate issued).
#
# Routing notes:
#   · metaserver's fastify routes are /auth/wx, /save ... (no /api prefix), so use handle_path to strip /api before forwarding.
#   · gateway control-plane WS binds path=/gw, gameserver data-plane WS binds path=/ws; paths must be preserved → use handle (no prefix stripping).
#   · matchsvc / gateway internal HTTP / meta internal routes (/internal/*) are not exposed to public (no route, internal cluster calls only).

{$NW_DOMAIN::80} {
	# Control-plane WS: room / matchmaking (preserve /gw path)
	handle /gw* {
		reverse_proxy gateway:8082
	}

	# Data-plane WS: lockstep battle (preserve /ws path)
	handle /ws* {
		reverse_proxy gameserver:8081
	}

	# Liveness probe: route /health to worldsvc (its /health sends CORS headers, so the
	# client's cross-origin reachability probe can read the status instead of being
	# blocked by CORS and falling through to the CORS-less fallback below).
	handle /health {
		reverse_proxy worldsvc:18084
	}

	# SLG overworld REST (S8, fourth public face: map/territory/auction, preserve path)
	handle /world* {
		reverse_proxy worldsvc:18084
	}
	handle /auction* {
		reverse_proxy worldsvc:18084
	}
	# Sect (SLG alliance) + nation/world public chat channels live in worldsvc too (S6-4/B7)
	handle /sect* {
		reverse_proxy worldsvc:18084
	}
	handle /nation* {
		reverse_proxy worldsvc:18084
	}

	# Social service (fifth public face: friends/DMs/mail/clan, preserve path)
	handle /social* {
		reverse_proxy socialsvc:8085
	}

	# Analytics event collection (A9, public endpoints /analytics/config + /analytics/events; preserve path)
	handle /analytics* {
		reverse_proxy analyticsvc:18085
	}

	# REST: strip /api prefix then forward to metaserver
	handle_path /api/* {
		reverse_proxy metaserver:8080
	}

	# Ops admin API (not player-reachable): only accessible via ops Worker reverse proxy; must include shared secret header
	# X-Ops-Proxy-Secret == {$NW_OPS_PROXY_SECRET}, otherwise 403. Strips /ops prefix then forwards to admin:8083.
	# Player direct access to https://<domain>/ops/* without secret → 403. See design/product/deploy-cloudflare.md §6.
	handle /ops/* {
		@noSecret not header X-Ops-Proxy-Secret {$NW_OPS_PROXY_SECRET}
		respond @noSecret 403
		uri strip_prefix /ops
		reverse_proxy admin:8083
	}

	# Fallback
	handle {
		respond "Notebook Wars server" 200
	}
}

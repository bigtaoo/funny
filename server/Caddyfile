# 反代（C-3 / S1-M / S8）：/api/* → metaserver、/gw → gateway(控制面 WS)、/ws → gameserver(数据面 WS)、
# /world,/family,/auction → worldsvc(SLG 大世界 REST)。
# 站点地址由 {$NW_DOMAIN} 注入：
#   · 真域名（如 nw.example.com）→ Caddy 自动签 Let's Encrypt 证书，全程 HTTPS/WSS。
#   · 缺省 :80 → 仅 HTTP（本机 / 无域名联调用；此时不签证书）。
#
# 路由要点：
#   · metaserver 的 fastify 路由是 /auth/wx、/save …（不含 /api 前缀），故用 handle_path 剥掉 /api 再转发。
#   · gateway 控制面 WS 绑 path=/gw、gameserver 数据面 WS 绑 path=/ws，必须保留路径 → 用 handle（不剥前缀）。
#   · matchsvc / gateway 内部 HTTP / meta 内部路由（/internal/*）不暴露公网（无路由，仅集群内调用）。

{$NW_DOMAIN::80} {
	# 控制面 WS：房间 / 匹配（保留 /gw 路径）
	handle /gw* {
		reverse_proxy gateway:8082
	}

	# 数据面 WS：锁步对战（保留 /ws 路径）
	handle /ws* {
		reverse_proxy gameserver:8081
	}

	# SLG 大世界 REST（S8，第四公网面：地图/领地/家族/拍卖，保留路径）
	handle /world* {
		reverse_proxy worldsvc:18084
	}
	handle /family* {
		reverse_proxy worldsvc:18084
	}
	handle /auction* {
		reverse_proxy worldsvc:18084
	}

	# REST：剥掉 /api 前缀后转给 metaserver
	handle_path /api/* {
		reverse_proxy metaserver:8080
	}

	# 兜底
	handle {
		respond "Notebook Wars server" 200
	}
}

# 反代（C-3 / S1-M / S8）：/api/* → metaserver、/gw → gateway(控制面 WS)、/ws → gameserver(数据面 WS)、
# /world,/auction → worldsvc(SLG 大世界 REST)、/social/* → socialsvc(社交第五公网面)。
# 站点地址由 {$NW_DOMAIN} 注入：
#   · 真域名（如 nw.example.com）→ Caddy 自动签 Let's Encrypt 证书，全程 HTTPS/WSS。
#   · 缺省 :80 → 仅 HTTP（本机 / 无域名联调用；此时不签证书）。
#
# 路由要点：
#   · metaserver 的 fastify 路由是 /auth/wx、/save …（不含 /api 前缀），故用 handle_path 剥掉 /api 再转发。
#   · gateway 控制面 WS 绑 path=/gw、gameserver 数据面 WS 绑 path=/ws，必须保留路径 → 用 handle（不剥前缀）。
#   · matchsvc / gateway 内部 HTTP / meta 内部路由（/internal/*）不暴露公网（无路由，仅集群内调用）。

{$NW_DOMAIN::80} {
	# 控制面 WS：房间 / 匹配（保留 /gw 路径）
	handle /gw* {
		reverse_proxy gateway:8082
	}

	# 数据面 WS：锁步对战（保留 /ws 路径）
	handle /ws* {
		reverse_proxy gameserver:8081
	}

	# SLG 大世界 REST（S8，第四公网面：地图/领地/拍卖，保留路径）
	handle /world* {
		reverse_proxy worldsvc:18084
	}
	handle /auction* {
		reverse_proxy worldsvc:18084
	}

	# 社交服务（第五公网面：好友/私聊/邮件/家族，保留路径）
	handle /social* {
		reverse_proxy socialsvc:8085
	}

	# Analytics 事件采集（A9，公开端点 /analytics/config + /analytics/events；保留路径）
	handle /analytics* {
		reverse_proxy analyticsvc:18085
	}

	# REST：剥掉 /api 前缀后转给 metaserver
	handle_path /api/* {
		reverse_proxy metaserver:8080
	}

	# 运维后台 admin API（玩家不可达）：仅经 ops Worker 反代进来，必须带共享密钥头
	# X-Ops-Proxy-Secret == {$NW_OPS_PROXY_SECRET}，否则 403。剥掉 /ops 前缀后转 admin:8083。
	# 玩家直连 https://<域>/ops/* 无密钥 → 403。见 design/product/deploy-cloudflare.md §6。
	handle /ops/* {
		@noSecret not header X-Ops-Proxy-Secret {$NW_OPS_PROXY_SECRET}
		respond @noSecret 403
		uri strip_prefix /ops
		reverse_proxy admin:8083
	}

	# 兜底
	handle {
		respond "Notebook Wars server" 200
	}
}

{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "title": "Notebook Wars — 客户端日志（定向采集）",
  "uid": "nw-client-logs",
  "tags": ["notebook-wars", "logs", "client"],
  "timezone": "",
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "description": "运营按 9 位 publicId 远程拉取单个玩家的客户端日志（FEATURE_FLAGS_DESIGN §9）。先在 ops『功能开关』把目标 publicId 填进想要级别的 client_log_* flag（pct 设 0、仅 allowPublicIds 命中），客户端轮询 bootstrap 命中后即批量上报。label 仅 {source=client, level}，publicId/tag/msg 入行内（logfmt）。",
  "templating": {
    "list": [
      {
        "name": "publicId",
        "label": "玩家 publicId(9 位)",
        "type": "textbox",
        "current": { "text": "", "value": "" }
      },
      {
        "name": "level",
        "label": "级别",
        "type": "query",
        "datasource": { "type": "loki", "uid": "loki" },
        "query": { "label": "level", "stream": "{source=\"client\"}", "type": 1 },
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "allValue": ".+",
        "current": { "text": "All", "value": "$__all" }
      },
      {
        "name": "search",
        "label": "关键字",
        "type": "textbox",
        "current": { "text": "", "value": "" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "客户端日志速率（按级别）",
      "type": "timeseries",
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "时间窗内 source=client 日志速率，按 level 堆叠。无数据 = 当前无玩家被定向（client_log_* 未填该玩家 publicId）。",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "bars", "fillOpacity": 60, "stacking": { "mode": "normal" } } }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "editorMode": "code",
          "expr": "sum by (level) (count_over_time({source=\"client\", level=~\"$level\"} | logfmt | publicId=~\"$publicId.*\" |~ \"(?i)$search\" [$__auto]))",
          "legendFormat": "{{level}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "客户端错误数（窗口内）",
      "type": "stat",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 7, "w": 5, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["sum"] }, "colorMode": "background", "graphMode": "area" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "editorMode": "code",
          "expr": "sum(count_over_time({source=\"client\", level=\"error\"} | logfmt | publicId=~\"$publicId.*\" [$__auto]))",
          "legendFormat": "errors"
        }
      ]
    },
    {
      "id": 3,
      "title": "上报玩家数（被定向的 publicId 个数）",
      "type": "stat",
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "时间窗内有日志上报的不同 publicId 数（即当前实际被采集的玩家数）。",
      "gridPos": { "h": 7, "w": 7, "x": 17, "y": 0 },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "blue", "value": null } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "editorMode": "code",
          "queryType": "instant",
          "expr": "count(sum by (publicId) (count_over_time({source=\"client\"} | logfmt [$__range])))",
          "legendFormat": "players"
        }
      ]
    },
    {
      "id": 4,
      "title": "客户端日志（按 publicId / 级别 / 关键字 过滤）",
      "type": "logs",
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "顶部填玩家 publicId(留空=全部被采集玩家)。每行末尾 publicId=…tag=…msg=… 即客户端上报的结构化字段。",
      "gridPos": { "h": 14, "w": 24, "x": 0, "y": 7 },
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "editorMode": "code",
          "expr": "{source=\"client\", level=~\"$level\"} | logfmt | publicId=~\"$publicId.*\" |~ \"(?i)$search\"",
          "maxLines": 2000
        }
      ]
    }
  ]
}

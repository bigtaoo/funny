{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "title": "Notebook Wars — Client Logs (Targeted Collection)",
  "uid": "nw-client-logs",
  "tags": ["notebook-wars", "logs", "client"],
  "timezone": "",
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "description": "Operations remotely pulls client logs for a specific player by 9-digit publicId (FEATURE_FLAGS_DESIGN §9). First add the target publicId to the desired level's client_log_* flag in ops 'Feature Flags' (set pct to 0, target via allowPublicIds only); the client polls bootstrap and on a match begins bulk reporting. Labels are only {source=client, level}; publicId/tag/msg are inlined (logfmt).",
  "templating": {
    "list": [
      {
        "name": "publicId",
        "label": "Player publicId (9 digits)",
        "type": "textbox",
        "current": { "text": "", "value": "" }
      },
      {
        "name": "level",
        "label": "Level",
        "type": "query",
        "datasource": { "type": "loki", "uid": "loki" },
        "query": { "label": "level", "stream": "{source=\"client\"}", "type": 1 },
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "allValue": ".+",
        "current": { "text": "All", "value": "$__all" }
      },
      {
        "name": "search",
        "label": "Keyword",
        "type": "textbox",
        "current": { "text": "", "value": "" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Client Log Rate (by level)",
      "type": "timeseries",
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "Rate of source=client logs within the time window, stacked by level. No data = no players currently targeted (no player publicId set in client_log_* flags).",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "bars", "fillOpacity": 60, "stacking": { "mode": "normal" } } }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "editorMode": "code",
          "expr": "sum by (level) (count_over_time({source=\"client\", level=~\"$level\"} | logfmt | publicId=~\"$publicId.*\" |~ \"(?i)$search\" [$__auto]))",
          "legendFormat": "{{level}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Client Error Count (within window)",
      "type": "stat",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 7, "w": 5, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["sum"] }, "colorMode": "background", "graphMode": "area" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "editorMode": "code",
          "expr": "sum(count_over_time({source=\"client\", level=\"error\"} | logfmt | publicId=~\"$publicId.*\" [$__auto]))",
          "legendFormat": "errors"
        }
      ]
    },
    {
      "id": 3,
      "title": "Reporting Players (count of targeted publicIds)",
      "type": "stat",
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "Number of distinct publicIds with log reports in the time window (i.e. the number of players currently being collected).",
      "gridPos": { "h": 7, "w": 7, "x": 17, "y": 0 },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "blue", "value": null } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "editorMode": "code",
          "queryType": "instant",
          "expr": "count(sum by (publicId) (count_over_time({source=\"client\"} | logfmt [$__range])))",
          "legendFormat": "players"
        }
      ]
    },
    {
      "id": 4,
      "title": "Client Logs (filter by publicId / level / keyword)",
      "type": "logs",
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "Enter player publicId at the top (leave blank = all currently collected players). Each line ends with publicId=…tag=…msg=… — the structured fields reported by the client.",
      "gridPos": { "h": 14, "w": 24, "x": 0, "y": 7 },
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "editorMode": "code",
          "expr": "{source=\"client\", level=~\"$level\"} | logfmt | publicId=~\"$publicId.*\" |~ \"(?i)$search\"",
          "maxLines": 2000
        }
      ]
    }
  ]
}

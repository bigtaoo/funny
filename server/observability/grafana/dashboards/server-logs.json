{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "title": "Notebook Wars — Server Logs",
  "uid": "nw-server-logs",
  "tags": ["notebook-wars", "logs"],
  "timezone": "",
  "schemaVersion": 39,
  "version": 3,
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "1m",
  "templating": {
    "list": [
      {
        "name": "svc",
        "label": "Service",
        "type": "query",
        "datasource": { "type": "loki", "uid": "loki" },
        "query": { "label": "svc", "stream": "", "type": 1 },
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "allValue": ".+",
        "current": { "text": "All", "value": "$__all" }
      },
      {
        "name": "level",
        "label": "Level",
        "type": "query",
        "datasource": { "type": "loki", "uid": "loki" },
        "query": { "label": "level", "stream": "", "type": 1 },
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "allValue": ".+",
        "current": { "text": "All", "value": "$__all" }
      },
      {
        "name": "search",
        "label": "Keyword",
        "type": "textbox",
        "current": { "text": "", "value": "" }
      },
      {
        "name": "roomId",
        "label": "roomId (match timeline)",
        "type": "textbox",
        "current": { "text": "", "value": "" }
      }
    ]
  },
  "panels": [
    {
      "id": 8,
      "title": "Service Health (each service emits a heartbeat every 5 minutes when idle; line drops = service may be down)",
      "type": "timeseries",
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "Number of heartbeat entries per svc within 5 minutes. Normal is ≥1 per interval; a line dropping to 0 or going missing = the process is not sending heartbeats, likely down or collection is broken.",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "showPoints": "always", "pointSize": 6, "spanNulls": false }, "min": 0 }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "editorMode": "code",
          "expr": "sum by (svc) (count_over_time({svc=~\".+\"} |= \"heartbeat\" [5m]))",
          "legendFormat": "{{svc}}"
        }
      ]
    },
    {
      "id": 1,
      "title": "Log Rate (by level)",
      "type": "timeseries",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 6 },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "bars", "fillOpacity": 60, "stacking": { "mode": "normal" } } }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "editorMode": "code",
          "expr": "sum by (level) (count_over_time({svc=~\"$svc\", level=~\"$level\"} |~ \"(?i)$search\" [$__auto]))",
          "legendFormat": "{{level}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Error Count per Service (within time window)",
      "type": "bargauge",
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "Number of error entries per svc within the time range — see at a glance which service is erroring.",
      "gridPos": { "h": 7, "w": 7, "x": 12, "y": 6 },
      "fieldConfig": { "defaults": { "color": { "mode": "continuous-GrYlRd" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "orientation": "horizontal", "displayMode": "gradient", "showUnfilled": true },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "editorMode": "code",
          "queryType": "instant",
          "expr": "sum by (svc) (count_over_time({level=\"error\"} [$__range]))",
          "legendFormat": "{{svc}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Total Errors (within window)",
      "type": "stat",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 7, "w": 5, "x": 19, "y": 6 },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["sum"] }, "colorMode": "background", "graphMode": "area" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "editorMode": "code",
          "expr": "sum(count_over_time({svc=~\"$svc\", level=\"error\"} |~ \"(?i)$search\" [$__auto]))",
          "legendFormat": "errors"
        }
      ]
    },
    {
      "id": 3,
      "title": "Logs (filter by service / level / keyword)",
      "type": "logs",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 13 },
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "editorMode": "code",
          "expr": "{svc=~\"$svc\", level=~\"$level\"} |~ \"(?i)$search\"",
          "maxLines": 1000
        }
      ]
    },
    {
      "id": 5,
      "title": "Errors Only (selected services)",
      "type": "logs",
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "Shows only level=error entries, constrained by the 'Service' dropdown at the top.",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 25 },
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "editorMode": "code",
          "expr": "{svc=~\"$svc\", level=\"error\"}",
          "maxLines": 500
        }
      ]
    },
    {
      "id": 6,
      "title": "Matchmaking Pipeline Quick View (enqueue → pair → start game)",
      "type": "logs",
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "Key matchmaking pipeline events from gateway/matchsvc/gameserver — use for diagnosing game start failures.",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 25 },
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "editorMode": "code",
          "expr": "{svc=~\"gateway|matchsvc|gameserver\"} |~ \"enqueue|pair matched|match starting|match_found|GAME_UNAVAILABLE|room created|room_create\"",
          "maxLines": 500
        }
      ]
    },
    {
      "id": 7,
      "title": "Single Match Timeline (enter roomId at top)",
      "type": "logs",
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "Enter a roomId in the top input box to pull all logs spanning gateway→matchsvc→game→meta for a single match into one timeline (ascending). Leave blank to show all lines that contain a roomId.",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 34 },
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Ascending"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "editorMode": "code",
          "expr": "{svc=~\"gateway|matchsvc|gameserver|meta\"} | logfmt | roomId=~\"$roomId\"",
          "maxLines": 1000
        }
      ]
    }
  ]
}

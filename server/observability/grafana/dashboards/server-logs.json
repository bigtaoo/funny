{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "title": "Notebook Wars — 服务端日志",
  "uid": "nw-server-logs",
  "tags": ["notebook-wars", "logs"],
  "timezone": "",
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "svc",
        "label": "服务",
        "type": "query",
        "datasource": { "type": "loki", "uid": "loki" },
        "query": { "label": "svc", "stream": "", "type": 1 },
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "allValue": ".+",
        "current": { "text": "All", "value": "$__all" }
      },
      {
        "name": "level",
        "label": "级别",
        "type": "query",
        "datasource": { "type": "loki", "uid": "loki" },
        "query": { "label": "level", "stream": "", "type": 1 },
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "allValue": ".+",
        "current": { "text": "All", "value": "$__all" }
      },
      {
        "name": "search",
        "label": "关键字",
        "type": "textbox",
        "current": { "text": "", "value": "" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "日志速率（按级别）",
      "type": "timeseries",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 7, "w": 18, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "bars", "fillOpacity": 60, "stacking": { "mode": "normal" } } }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum by (level) (count_over_time({svc=~\"$svc\", level=~\"$level\"} |~ \"(?i)$search\" [$__auto]))",
          "legendFormat": "{{level}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "错误数（窗口内）",
      "type": "stat",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 7, "w": 6, "x": 18, "y": 0 },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["sum"] }, "colorMode": "background", "graphMode": "area" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(count_over_time({svc=~\"$svc\", level=\"error\"} |~ \"(?i)$search\" [$__auto]))",
          "legendFormat": "errors"
        }
      ]
    },
    {
      "id": 3,
      "title": "日志",
      "type": "logs",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 18, "w": 24, "x": 0, "y": 7 },
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{svc=~\"$svc\", level=~\"$level\"} |~ \"(?i)$search\"",
          "maxLines": 1000
        }
      ]
    }
  ]
}

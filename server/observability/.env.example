# 观测栈环境变量。复制为 observability/.env 后填写：
#   cp observability/.env.example observability/.env
# 起栈：docker compose -f observability/docker-compose.obs.yml --env-file observability/.env up -d

# Grafana 内置管理员（第二层登录；第一层是 CF Access）。密码用强随机串：
#   openssl rand -hex 16
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=

# Grafana 对外根地址（cloudflared 隧道域名）。决定 Grafana 生成的链接/重定向。
GF_ROOT_URL=https://grafana.gamestao.com

# Cloudflare Tunnel 令牌（CF Zero Trust → Networks → Tunnels 建隧道后复制）。
# 留空则注释掉 compose 里的 cloudflared 服务，改用 SSH 隧道访问（见 README）。
CF_TUNNEL_TOKEN=

# Observability stack environment variables. Copy to observability/.env and fill in:
#   cp observability/.env.example observability/.env
# Start stack: docker compose -f observability/docker-compose.obs.yml --env-file observability/.env up -d

# Grafana built-in admin credentials (second authentication layer; first layer is CF Access). Use a strong random password:
#   openssl rand -hex 16
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=

# Grafana external root URL (cloudflared tunnel domain). Determines the links/redirects Grafana generates.
GF_ROOT_URL=https://grafana.gamestao.com

# Cloudflare Tunnel token (CF Zero Trust → Networks → Tunnels → create tunnel, then copy).
# Can be left empty: by default `up -d` does not start cloudflared (it's under profile "tunnel"); fill it in and use
# `--profile tunnel up -d` to bring the tunnel up. Without tunnel, use SSH tunneling to access Grafana (see README).
CF_TUNNEL_TOKEN=

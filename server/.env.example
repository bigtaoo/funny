# Production environment variable template (C-3). Copy to .env and fill in: cp .env.example .env
# docker compose -f docker-compose.prod.yml --env-file .env up -d --build

# JWT signing secret — must be changed to a strong random string in production (e.g. openssl rand -hex 32). Leaking this allows forging arbitrary account tokens.
NW_JWT_SECRET=change-me-to-a-strong-random-secret

# Internal service key (S1-M) — shared by gateway/matchsvc/gameserver/meta: signs match tickets + fallback for inter-service internal HTTP auth.
# Must be changed to a strong random string in production; leaking this allows forging tickets to directly connect to game / call internal settlement endpoints.
NW_INTERNAL_KEY=change-me-to-a-strong-random-internal-key

# Advanced (optional, S12-1, SERVER_API §8.0): per-caller internal key registry, one independent key per caller.
# When enabled, internal HTTP auth strictly validates by caller (localized leak + identifiable + per-service rotation); the old single NW_INTERNAL_KEY
# is no longer accepted for internal HTTP in strict mode (but ticket HMAC still uses only NW_INTERNAL_KEY, unrelated to this registry).
# Format: caller=key,caller=key (caller ∈ gateway/gameserver/matchsvc/meta/commercial/worldsvc/admin/analyticsvc);
# Leave empty = fall back to single shared key mode (default, zero behavior change). Enabling requires configuring the same registry for all processes.
# NW_INTERNAL_KEYS=gateway=rand1,gameserver=rand2,matchsvc=rand3,meta=rand4,commercial=rand5,worldsvc=rand6,admin=rand7,analyticsvc=rand8

# —— Mongo connection ——
# docker-compose.prod.yml (with its own mongo container): connection string is fixed as mongodb://mongo:27017/?replicaSet=rs0 inside compose,
#   leave this variable empty.
# docker-compose.cloud.yml (externally-managed Mongo, e.g. Atlas M0): must fill in the mongodb+srv:// string provided by Atlas.
#   ⚠ Atlas M0 connection limit is 500; 5 processes connecting to the DB each default to 100 connections which will hit the cap → must append &maxPoolSize=10 at the end.
#   Example: mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority&maxPoolSize=10
NW_MONGO_URI=
# Mongo database name (meta business DB; commercial/world/admin/analytics each use separate DB names below, sharing the same connection string/cluster)
NW_MONGO_DB=notebook_wars

# commercial-only DB name (S5, wallet/ledger/orders/recharge/gacha; physically isolated from meta DB, reuses same instance connection string)
NW_COMM_MONGO_DB=notebook_wars_commercial

# —— SLG overworld worldsvc (S8, seventh process, public REST fourth face /world,/family,/auction) ——
# Dedicated DB name (map/territory/march/clan/auction; physically isolated from business DB, reuses same instance connection string).
NW_WORLD_MONGO_DB=notebook_wars_world
# Redis connection string: docker compose includes a built-in redis service; default is redis://redis:6379, usually no need to fill.
# Leave empty = degrade (march scheduler falls back to Mongo), set '' to explicitly disable.
# pm2 / bare-metal deployments need to fill manually (e.g. redis://127.0.0.1:6379).
NW_WORLD_REDIS_URL=
# gateway subscribes to the same Redis for clan channel real-time fan-out (S8-4b). Must point to the same instance as NW_WORLD_REDIS_URL;
# Leave empty = clan channel real-time push degrades (REST polling still works). pm2/bare-metal needs to fill manually (e.g. redis://127.0.0.1:6379).
NW_GW_REDIS_URL=

# Site address: fill with a real domain (e.g. nw.example.com) → Caddy auto-signs HTTPS; leave :80 for HTTP (local integration testing)
NW_DOMAIN=:80

# Client-reachable address for the data-plane game WS (written into match ticket + matchsvc allocation fallback).
# Leave as default for local testing; change to wss://nw.example.com/ws when using a real domain (matching NW_DOMAIN).
NW_GAME_PUBLIC_WS_URL=ws://localhost/ws

# WeChat jscode2session (mini-game login); leave empty to fall back to dev openid, does not affect Web/CrazyGames device login
NW_WX_APPID=
NW_WX_SECRET=

# —— Google OAuth (SA-2, initially supporting google) ——
# Create OAuth2 credentials (Web application type) in Google Cloud Console, then fill in.
# Leave empty → /auth/oauth?provider=google returns OAUTH_FAILED (does not affect other login methods).
NW_OAUTH_GOOGLE_CLIENT_ID=
NW_OAUTH_GOOGLE_CLIENT_SECRET=

# —— IAP real receipt verification (S4-1 / C1, verification logic in commercial/src/iap.ts) ——
# Four-platform credentials; leaving any platform empty → that platform's receipt verification returns failure (client recharge request receives INVALID_RECEIPT), no coins issued.
# Launch checklist + credential request locations: design/game/IAP_CREDENTIALS.md.

# Apple App Store (StoreKit 1 receipt): App Store Connect → "In-App Purchases" → App-Specific Shared Secret.
# Leave empty → apple receipt verification unavailable.
NW_APPLE_PASSWORD=

# Google Play (androidpublisher v3): GCP service account JSON (full string, including private_key + client_email),
# must grant the service account "View financial data/Manage orders" in Play Console.
NW_GOOGLE_SERVICE_ACCOUNT_JSON=
# Android app package name (default com.nw.game); must match the published package name.
NW_GOOGLE_PACKAGE_NAME=

# WeChat Pay V3: merchant ID + V3 APIKey (generated in merchant platform "API Security", 32 bytes).
# Leave empty → WeChat Pay receipt verification unavailable (client recharge request returns INVALID_RECEIPT).
NW_WX_PAY_MCH_ID=
NW_WX_PAY_API_KEY_V3=

# Stripe Web recharge: fill sk_live_* to enable real receipt verification, sk_test_* for sandbox testing.
# Leave empty → Stripe receipt verification unavailable.
NW_STRIPE_SECRET_KEY=

# Product ID → tier mapping (optional, shared by Apple/Google, format productId:tier,productId:tier).
# If not set, uses built-in default convention ${NW_IAP_BUNDLE}.coins.<tierId>, where <tierId> is an
# IAP_TIERS key (t099/t199/t499/t999/t1999/t4999/t9999), e.g. com.nw.coins.t499.
NW_IAP_PRODUCT_MAP=
# Bundle prefix for default product IDs (only used when NW_IAP_PRODUCT_MAP is not configured).
NW_IAP_BUNDLE=com.nw

# IAP dev stub switch: true = receipts starting with `tier:` or platform=dev use the dev stub (local integration only).
# Default (non-production): dev stub auto-enabled when WeChat/Stripe/Apple/Google are all unconfigured; recommend explicit false when real channels are configured.
# ⚠️ Hardening (L2-3): dev stub is force-disabled under NODE_ENV=production; if NW_IAP_DEV=true is still set, commercial process refuses to start.
NW_IAP_DEV=

# IAP amount → tier mapping (optional, shared by WeChat/Stripe, format amount:tier,amount:tier).
# If not set, the built-in default matches Stripe USD prices (cents) to tiers via IAP_TIERS_LIST.usdCents
# (99→t099, 199→t199, 499→t499, 999→t999, 1999→t1999, 4999→t4999, 9999→t9999).
# WeChat is priced in fen (CNY) with no canonical price — WeChat deployments MUST set this (e.g. 3500:t499,...).
NW_IAP_AMOUNT_MAP=

# —— Paddle (Web recharge channel, metaserver/src/paddle.ts; separate from /iap/verify above) ——
# Web clients recharge via Paddle Checkout: POST /shop/paddle/checkout → Paddle.js → async /paddle/webhook credits coins.
# Launch checklist: design/game/IAP_CREDENTIALS.md §1.1. Leave empty → web recharge disabled (Coins tab errors).
NW_PADDLE_API_KEY=
NW_PADDLE_WEBHOOK_SECRET=
# Client-side Paddle.js token (ptok_/live_/test_, client-safe). Surfaced to the web client via GET /bootstrap
# when set; prefix test_ auto-selects Paddle sandbox on the client.
NW_PADDLE_CLIENT_TOKEN=
# Tier → Paddle price ID map: t499:pri_xxx,t999:pri_yyy,...
NW_PADDLE_PRICE_IDS=
# true = use Paddle sandbox API (default: production).
NW_PADDLE_SANDBOX=

# —— Rewarded video ad signature verification (C2, metaserver/src/ads.ts) ——
# Client adToken HMAC verification shared secret; leave empty → that platform's adToken passes through (relies only on credential uniqueness + daily cap to prevent abuse).
# AdMob client key (admob_client).
NW_ADMOB_CLIENT_KEY=
# WeChat rewarded video client key (wechat_client).
NW_WECHAT_ADS_CLIENT_KEY=
# WeChat ads SSV server-side callback key (WeChat platform server callback signature verification).
NW_WECHAT_ADS_KEY=

# —— Process alert Webhook (S4-3) ——
# Slack/Discord/WeCom webhook; triggers POST alert on uncaughtException/unhandledRejection.
# Leave empty = log only, no alert sent.
NW_ALERT_WEBHOOK_URL=

# —— Mongo backup (S4-3, deploy/backup-mongo.sh) ——
# Optional S3 bucket name (when configured, backup script additionally runs aws s3 cp to this bucket).
NW_BACKUP_S3_BUCKET=

# —— Analytics event collection service (A9, ninth process, not player-reachable) ——
# Dedicated DB name (raw events/sessions/funnels; physically isolated from business DB, reuses same instance connection string).
NW_ANALYTICS_MONGO_DB=notebook_wars_analytics

# —— Ops admin backend (S7, OPS_DESIGN) ——
# admin analytics query: analyticsvc internal base URL (when configured, data analytics page can display events/DAU/funnels).
# NW_ANALYTICS_BASE_URL=http://localhost:18085
# admin-only JWT secret (strictly isolated from player NW_JWT_SECRET) — must be changed to strong random string in production.
NW_ADMIN_JWT_SECRET=change-me-to-a-strong-random-admin-secret
# admin-only DB name (ops accounts/tickets/audit/snapshots; physically isolated from business DB).
NW_ADMIN_MONGO_DB=notebook_wars_admin
# Bootstrap seed super-admin (recommend clearing after first deployment, manage accounts via the admin panel instead; leave empty to skip seeding, requires manually creating the first super-admin).
NW_ADMIN_SEED_USER=
NW_ADMIN_SEED_PASS=
# Shared secret header for ops admin public entry: ops Worker injects X-Ops-Proxy-Secret when reverse-proxying admin,
# Caddy /ops/* route verifies it; no secret → 403 (players cannot reach admin even if they bypass CF Access).
# Generate: openssl rand -hex 32; the same value must be set in the ops Worker via `wrangler secret put ADMIN_PROXY_SECRET -c wrangler/ops.jsonc`.
# Leave empty = /ops/* channel returns 403 for all (admin remains reachable only within the cluster, frontend cannot connect to the live backend). See deploy-cloudflare.md §6.
NW_OPS_PROXY_SECRET=

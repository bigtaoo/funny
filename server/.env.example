# 生产环境变量样板（C-3）。拷成 .env 后填写：cp .env.example .env
# docker compose -f docker-compose.prod.yml --env-file .env up -d --build

# JWT 签名密钥——生产必须改成强随机串（如 openssl rand -hex 32），泄露=可伪造任意账号 token。
NW_JWT_SECRET=change-me-to-a-strong-random-secret

# 内部服务密钥（S1-M）——gateway/matchsvc/gameserver/meta 共用一把：签 match ticket + 服务间内部 HTTP 鉴权回退。
# 生产必改成强随机串；泄露=可伪造 ticket 直连 game / 调内部结算端点。
NW_INTERNAL_KEY=change-me-to-a-strong-random-internal-key

# 进阶（可选，S12-1，SERVER_API §8.0）：per-caller 内部密钥注册表，每个调用方一把独立密钥，
# 启用后内部 HTTP 鉴权按调用方严格校验（泄露局部化 + 可识别 + 按服务轮换），旧的单一 NW_INTERNAL_KEY
# 在严格模式下不再被内部 HTTP 接受（但 ticket HMAC 仍只用 NW_INTERNAL_KEY，与本表无关）。
# 格式 caller=key,caller=key（caller ∈ gateway/gameserver/matchsvc/meta/commercial/worldsvc/admin/analyticsvc）；
# 留空 = 退回单一共享密钥模式（默认，零行为变更）。启用须给所有进程配同一份注册表。
# NW_INTERNAL_KEYS=gateway=rand1,gameserver=rand2,matchsvc=rand3,meta=rand4,commercial=rand5,worldsvc=rand6,admin=rand7,analyticsvc=rand8

# —— Mongo 连接 ——
# docker-compose.prod.yml（自带 mongo 容器）：连接串在 compose 内固定 mongodb://mongo:27017/?replicaSet=rs0，
#   本变量留空即可。
# docker-compose.cloud.yml（外接托管 Mongo，如 Atlas M0）：必须填 Atlas 提供的 mongodb+srv:// 串。
#   ⚠ Atlas M0 连接数上限 500，5 个连库进程默认各开 100 连接会顶满 → 末尾务必加 &maxPoolSize=10。
#   例：mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority&maxPoolSize=10
NW_MONGO_URI=
# Mongo 数据库名（meta 业务库；commercial/world/admin/analytics 各用下方独立库名，共用同一连接串/集群）
NW_MONGO_DB=notebook_wars

# commercial 专属库名（S5，钱包/流水/订单/充值/盲盒；与 meta 库物理隔离，连接串复用同实例）
NW_COMM_MONGO_DB=notebook_wars_commercial

# —— SLG 大世界 worldsvc（S8，第七进程，公网 REST 第四面 /world,/family,/auction）——
# 专属库名（地图/领地/行军/家族/拍卖；与业务库物理隔离，连接串复用同实例）。
NW_WORLD_MONGO_DB=notebook_wars_world
# Redis 连接串：docker compose 已内置 redis 服务，默认值为 redis://redis:6379，通常不需要填。
# 留空 = 降级（行军调度走 Mongo 兜底），填 '' 可显式关闭。
# pm2 / 裸机部署时需手动填（如 redis://127.0.0.1:6379）。
NW_WORLD_REDIS_URL=
# gateway 订阅同一 Redis 做宗门频道实时扇出（S8-4b）。须与 NW_WORLD_REDIS_URL 指向同实例；
# 留空 = 宗门频道实时推送降级（仍可 REST 轮询）。pm2/裸机需手动填（如 redis://127.0.0.1:6379）。
NW_GW_REDIS_URL=

# 站点地址：填真域名（如 nw.example.com）→ Caddy 自动签 HTTPS；留 :80 走 HTTP（本机联调）
NW_DOMAIN=:80

# 数据面 game WS 的客户端可达地址（写进 match ticket + matchsvc 分配兜底）。
# 本机联调留默认；设真域名时改 wss://nw.example.com/ws（与 NW_DOMAIN 一致）。
NW_GAME_PUBLIC_WS_URL=ws://localhost/ws

# 微信 jscode2session（小游戏登录）；留空走 dev openid 回退，不影响 Web/CrazyGames 设备登录
NW_WX_APPID=
NW_WX_SECRET=

# —— Google OAuth（SA-2，首期支持 google）——
# 在 Google Cloud Console 创建 OAuth2 凭据（Web 应用类型），填入。
# 留空则 /auth/oauth?provider=google 返回 OAUTH_FAILED（不影响其他登录方式）。
NW_OAUTH_GOOGLE_CLIENT_ID=
NW_OAUTH_GOOGLE_CLIENT_SECRET=

# —— IAP 真实验单（S4-1 / C1，验签逻辑 commercial/src/iap.ts）——
# 四平台凭据；每个平台留空 → 该平台验单返失败（客户端充值请求收 INVALID_RECEIPT），不发币。
# 上线 checklist + 各凭据申请位置见 design/game/IAP_CREDENTIALS.md。

# Apple App Store（StoreKit 1 receipt）：App Store Connect →「App 内购买项目」→ App 专用共享密钥。
# 留空 → apple 验单不可用。
NW_APPLE_PASSWORD=

# Google Play（androidpublisher v3）：GCP 服务账户 JSON（整串，含 private_key + client_email），
# 须在 Play Console 授予该服务账户「查看财务数据/管理订单」权限。
NW_GOOGLE_SERVICE_ACCOUNT_JSON=
# Android 应用包名（默认 com.nw.game）；与上架包名一致。
NW_GOOGLE_PACKAGE_NAME=

# 微信支付 V3：商户号 + V3 APIKey（商户平台「API安全」处生成，32字节）。
# 留空 → 微信支付验单不可用（客户端充值请求返回 INVALID_RECEIPT）。
NW_WX_PAY_MCH_ID=
NW_WX_PAY_API_KEY_V3=

# Stripe Web 充值：填 sk_live_* 启用真实验单，sk_test_* 走沙盒测试。
# 留空 → Stripe 验单不可用。
NW_STRIPE_SECRET_KEY=

# 产品 ID → 档位映射（可选，Apple/Google 共用，格式 productId:tier,productId:tier）。
# 不填则用内置默认：${NW_IAP_BUNDLE}.coins.{small,mid,large}。
NW_IAP_PRODUCT_MAP=
# 默认产品 ID 的 bundle 前缀（仅在未配 NW_IAP_PRODUCT_MAP 时用）。
NW_IAP_BUNDLE=com.nw

# IAP dev 桩开关：true = receipt 以 `tier:` 开头或 platform=dev 时走 dev 桩（仅本地联调）。
# 默认（非生产）：微信/Stripe/Apple/Google 均未配置时自动开启 dev 桩；配置真实渠道时建议显式 false。
# ⚠️ 加固（L2-3）：NODE_ENV=production 下 dev 桩强制关闭；若仍设 NW_IAP_DEV=true，commercial 进程拒启。
NW_IAP_DEV=

# IAP 金额→档位映射（可选，微信/Stripe 共用，格式 amount:tier,amount:tier）。
# 不填则用内置默认：微信 600fen/3000fen/10000fen、Stripe 99cents/499cents/1499cents。
NW_IAP_AMOUNT_MAP=

# —— 激励视频广告验签（C2，metaserver/src/ads.ts）——
# 客户端 adToken HMAC 校验共享密钥；留空 → 该平台 adToken 放行（仅靠凭证唯一性 + 每日 cap 防刷）。
# AdMob 客户端密钥（admob_client）。
NW_ADMOB_CLIENT_KEY=
# 微信激励视频客户端密钥（wechat_client）。
NW_WECHAT_ADS_CLIENT_KEY=
# 微信广告 SSV 服务端回调密钥（wechat 平台服务端回调验签）。
NW_WECHAT_ADS_KEY=

# —— 进程告警 Webhook（S4-3）——
# Slack/Discord/企微 webhook；uncaughtException/unhandledRejection 时触发 POST 告警。
# 留空 = 只打日志，不发告警。
NW_ALERT_WEBHOOK_URL=

# —— Mongo 备份（S4-3，deploy/backup-mongo.sh）——
# 可选 S3 存储桶名（配置后备份脚本额外 aws s3 cp 到此桶）。
NW_BACKUP_S3_BUCKET=

# —— Analytics 事件采集服务（A9，第九进程，玩家不可达）——
# 专属库名（原始事件/会话/漏斗；与业务库物理隔离，连接串复用同实例）。
NW_ANALYTICS_MONGO_DB=notebook_wars_analytics

# —— 运维后台 admin（S7，OPS_DESIGN）——
# admin 埋点查询：analyticsvc 内部基址（填后数据分析页面可展示事件/DAU/漏斗）。
# NW_ANALYTICS_BASE_URL=http://localhost:18085
# admin 专用 JWT 密钥（与玩家 NW_JWT_SECRET 严格隔离）——生产必改强随机串。
NW_ADMIN_JWT_SECRET=change-me-to-a-strong-random-admin-secret
# admin 专属库名（运维账号/工单/审计/快照；与业务库物理隔离）。
NW_ADMIN_MONGO_DB=notebook_wars_admin
# 首启种子超管（首次部署后建议清空，改由后台增删账号；不填则不种子，需手动建首个超管）。
NW_ADMIN_SEED_USER=
NW_ADMIN_SEED_PASS=
# ops 运维后台公网入口的共享密钥头：ops Worker 反代 admin 时注入 X-Ops-Proxy-Secret，
# Caddy /ops/* 路由校验，无密钥→403（玩家即使绕过 CF Access 也打不进 admin）。
# 生成：openssl rand -hex 32；同一值需用 `wrangler secret put ADMIN_PROXY_SECRET -c wrangler.ops.jsonc` 填到 ops Worker。
# 留空 = /ops/* 通道全 403（admin 仍只集群内可达，前端连不上线上后端）。见 deploy-cloudflare.md §6。
NW_OPS_PROXY_SECRET=

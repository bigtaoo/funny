# 生产环境变量样板（C-3）。拷成 .env 后填写：cp .env.example .env
# docker compose -f docker-compose.prod.yml --env-file .env up -d --build

# JWT 签名密钥——生产必须改成强随机串（如 openssl rand -hex 32），泄露=可伪造任意账号 token。
NW_JWT_SECRET=change-me-to-a-strong-random-secret

# 内部服务密钥（S1-M）——gateway/gameserver/meta 共用一把：签 match ticket + 服务间内部 HTTP 鉴权。
# 生产必改成强随机串；泄露=可伪造 ticket 直连 game / 调内部结算端点。
NW_INTERNAL_KEY=change-me-to-a-strong-random-internal-key

# Mongo 数据库名（连接串在 compose 内固定 mongodb://mongo:27017/?replicaSet=rs0）
NW_MONGO_DB=notebook_wars

# 站点地址：填真域名（如 nw.example.com）→ Caddy 自动签 HTTPS；留 :80 走 HTTP（本机联调）
NW_DOMAIN=:80

# 数据面 game WS 的客户端可达地址（写进 match ticket + matchsvc 分配兜底）。
# 本机联调留默认；设真域名时改 wss://nw.example.com/ws（与 NW_DOMAIN 一致）。
NW_GAME_PUBLIC_WS_URL=ws://localhost/ws

# 微信 jscode2session（小游戏登录）；留空走 dev openid 回退，不影响 Web/CrazyGames 设备登录
NW_WX_APPID=
NW_WX_SECRET=
